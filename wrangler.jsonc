{
  "name": "aka-dog",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": [], // add "nodejs_compat" only if a runtime import needs Node built-ins
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
    // Phase 6 adds: "run_worker_first": ["/index/*"]
  },
  "observability": { "enabled": true }
  // Never set assets.not_found_handling to a static page — it bypasses the Worker and kills redirects.
}
