---
import Layout from "@/layouts/Layout.astro";
import {
  deprecationRows,
  type ResolvedView,
  resolveViewByPath,
} from "@/lib/views";

const segments = (Astro.params.path ?? "").split("/");
let view: ResolvedView;
try {
  view = resolveViewByPath(segments);
} catch {
  return new Response("Not found", {
    status: 404,
    headers: { "content-type": "text/plain" },
  });
}
---

<Layout title={view.title} description={view.description}>
  <h1>{view.title}</h1>
  <p>{view.description}</p>

  {
    view.kind === 'deprecated' ? (
      <ul>
        {deprecationRows(view.entries).map((row) => (
          <li>
            <code>{row.url}</code>
            {row.became ? (
              <>
                {' '}-> <code>{row.became}</code>
              </>
            ) : null}
            {row.until ? <> {'-'} retired {row.until}</> : null}
            {' '}- {row.entry.name}
          </li>
        ))}
      </ul>
    ) : (
      <ul>
        {view.entries.map((entry) => (
          <li>
            {entry.current?.[0] ? (
              <a href={`https://${entry.current[0].url}`}>{entry.name}</a>
            ) : (
              <span>{entry.name}</span>
            )}
            {entry.description ? <> - {entry.description}</> : null}
          </li>
        ))}
      </ul>
    )
  }
</Layout>
